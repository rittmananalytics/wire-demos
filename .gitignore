# Per-demo runtime state — restored from _seeds/<demo>/ by reset.sh.
# Note: */ matches exactly one path component, so these patterns ignore the
# working copies under demo*/ but leave the _seeds/<demo>/* canonical state
# tracked (those are two levels deep).
*/.wire/
*/dbt/
*/dashboards/
*/semantic_layer/
*/warehouse.duckdb
*/warehouse.duckdb.wal
*/logs/

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# macOS
.DS_Store

# dbt-core per-install telemetry UUID — varies by machine, must not be tracked
shared/profiles/.user.yml

# Editor
.vscode/
.idea/

# Don't ignore _seed/.gitkeep or expected_artifacts content
!*/_seed/.gitkeep
!*/expected_artifacts/**
